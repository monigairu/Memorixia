# このファイルをコピーして .env を作り、実際のキー値を入力する
# .env はコミットしない(ルートの .gitignore で除外済み)
#
# Google Cloud Console → 鍵と認証情報 で発行した3本のキー

# Maps SDK for Android 用キー(Androidアプリ制限: パッケージ名+SHA-1)
GOOGLE_MAPS_API_KEY_ANDROID=

# Maps SDK for iOS 用キー(iOSアプリ制限: バンドルID)
GOOGLE_MAPS_API_KEY_IOS=

# Places API (New) 用キー(アプリ制限なし。API制限+クォータ上限で保護。REQUIREMENT 7章)
# クライアントJSから直接fetchするため EXPO_PUBLIC_ プレフィックスが必須
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
